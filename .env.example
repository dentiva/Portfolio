# ── Anthropic ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Resend (email) ─────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_TO=you@example.com
# Must be from a domain you've verified in Resend:
EMAIL_FROM=alerts@yourdomain.com

# ── Dashboard auth ─────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change_me_to_something_long_and_random

# ── Public URL (for email "Open dashboard" links) ──────
# Railway will give you something like https://portfolio-monitor-production-abc.up.railway.app
PUBLIC_BASE_URL=http://localhost:8000

# ── Runtime ────────────────────────────────────────────
POLL_ON_STARTUP=true
# DATA_DIR=/data   # leave unset on Railway (auto-detected); set ./data locally
